{
  "name": "brandcn",
  "description": "brandcn is a CLI tool that lets you quickly pull and add high-quality brand logos to your project — just like adding components with shadcn/ui.",
  "version": "0.1.19",
  "author": "yonaries",
  "bin": {
    "brandcn": "./bin/run.js"
  },
  "bugs": "https://github.com/yonaries/brandcn/issues",
  "dependencies": {
    "@clack/core": "^0.5.0",
    "@clack/prompts": "^0.11.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.1",
    "picocolors": "^1.1.1",
    "zod": "^4.0.17",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./library",
    "LICENSE"
  ],
  "homepage": "https://github.com/yonaries/brandcn",
  "keywords": [
    "brandcn",
    "brand",
    "logo",
    "logos",
    "branding",
    "brand-logos",
    "brand-logos-cli",
    "brand-logos-cli-tool"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "repository": "yonaries/brandcn",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "clean": "shx rm -rf dist && rm -rf components",
    "dev": "NODE_ENV=development ./bin/dev.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "posttest": "bun run lint",
    "prepack": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "types": "dist/index.d.ts"
}
