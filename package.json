{
  "name": "brandcn-monorepo",
  "version": "0.1.9",
  "private": true,
  "description": "brandcn monorepo containing the CLI package and website",
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "prepare": "lefthook install --force",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "oxfmt --write .",
    "check": "oxlint . && oxfmt --check .",
    "check:fix": "oxlint --fix . && oxfmt --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@workspace/typescript-config": "workspace:*",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.17.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
